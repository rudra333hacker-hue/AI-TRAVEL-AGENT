# ── TripCraft AI v4.0 — Configuration ──
# Copy this file to .env and fill in your keys.

## REQUIRED
# Get a free NVIDIA NIM API key: https://build.nvidia.com
NVIDIA_API_KEY=nvapi-xxxx

## OPTIONAL — Enables live flight search via Amadeus (free tier: 2,000 req/month)
# Sign up: https://developers.amadeus.com
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=

## OPTIONAL — Enables real place/hotel search via Foursquare
# Sign up: https://location.foursquare.com/developer/
FOURSQUARE_API_KEY=

## OPTIONAL — Server settings
HOST=0.0.0.0
PORT=8000
SESSION_TTL_MINUTES=30
