# ── TripCraft AI v4.0 — Configuration ──
# Copy this file to .env and fill in your keys.

## REQUIRED
# Get a free NVIDIA NIM API key: https://build.nvidia.com
# Provide fallback keys to prevent rate-limiting or server busy errors.
NVIDIA_API_KEY=nvapi-xxxx
NVIDIA_API_KEY_2=nvapi-xxxx
NVIDIA_API_KEY_3=nvapi-xxxx

# Target model on NVIDIA NIM (default: moonshotai/kimi-k2.6)
NVIDIA_MODEL=moonshotai/kimi-k2.6

## OPTIONAL — Security header api-key check for production environment
TRIPCRAFT_API_KEY=

## OPTIONAL — Enables live flight search via Amadeus (free tier: 2,000 req/month)
# Sign up: https://developers.amadeus.com
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=

## OPTIONAL — Enables real place/hotel search via Foursquare
# Sign up: https://location.foursquare.com/developer/
FOURSQUARE_API_KEY=

## OPTIONAL — Server settings
HOST=0.0.0.0
PORT=8000
SESSION_TTL_MINUTES=30
